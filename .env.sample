# EchoForge environment variables — copy to .env and uncomment what you need.
# All variables are optional; defaults are shown in comments.

# ── Bridge ─────────────────────────────────────────────────────────────────

# ECHOFORGE_HOST=0.0.0.0
# ECHOFORGE_PORT=8765

# ── Daemon market data feeds ────────────────────────────────────────────────

# VALR exchange URL for REST order execution (default: mock-valr on localhost).
# Set to https://api.valr.com to execute on real VALR (requires API key in daemon).
# ECHOFORGE_EXCHANGE_URL=http://localhost:8766

# VALR WebSocket for live market data.
# Overrides the auto-derived WS_URL. Use wss://api.valr.com/ws/trade for direct VALR feed.
# When ECHOFORGE_EXCHANGE_URL=https://api.valr.com this is set automatically.
# ECHOFORGE_VALR_WS_URL=wss://api.valr.com/ws/trade

# Binance WebSocket URL (default: wss://stream.binance.com:9443/ws/btcusdt@trade).
# Daemon connects directly — no mock or proxy needed.
# ECHOFORGE_BINANCE_URL=wss://stream.binance.com:9443/ws/btcusdt@trade

# Comma-separated list of allowed CORS origins.
# Use '*' in development; set explicit origins in production.
# ECHOFORGE_CORS_ORIGINS=*

# ── NATS ───────────────────────────────────────────────────────────────────

# If unset, NATS publish is skipped silently (bridge still starts fine).
# NATS_URL=nats://localhost:4222

# ── Dashboard (Next.js — baked at build time) ──────────────────────────────

# URL the dashboard uses to reach the bridge.
# Change this if the bridge is running on a different host/port.
# NEXT_PUBLIC_BRIDGE_URL=http://localhost:8765

# ── Docker Compose port overrides ─────────────────────────────────────────

# BRIDGE_PORT=8765
# MOCK_VALR_PORT=8766
# TRACKER_PORT=8888
# NATS_PORT=4222
# DASHBOARD_PORT=3001

# ── Trystero tracker ────────────────────────────────────────────────────────

# Allow all WebTorrent rooms (default: true).
# Set to 'false' and populate TRACKER_ALLOW_HASHES to restrict rooms.
# TRACKER_ALLOW_ALL=true

# Comma-separated 8-char info-hash prefixes to allow when TRACKER_ALLOW_ALL=false.
# TRACKER_ALLOW_HASHES=a1b2c3d4,e5f6g7h8

# Set to any non-empty value to trust X-Forwarded-For (for reverse-proxy deployments).
# TRACKER_TRUST_PROXY=

# ── PHIC Governance ────────────────────────────────────────────────────────────
# Path to the config YAML that defines all preset values (single source of truth).
# Default: echoforge.config.yaml in the working directory.
# ECHOFORGE_CONFIG=echoforge.config.yaml

# Select the active preset on bridge startup: low | medium (default) | high
# ECHOFORGE_PHIC_PRESET=medium

# Individual field overrides — applied on top of the selected preset.
# Values must be valid JSON literals (numbers, booleans, JSON objects/arrays).
# These take precedence over the preset but are still overridden by localStorage.
# ECHOFORGE_PHIC_AUTONOMY_LEVEL=0.90
# ECHOFORGE_PHIC_MAX_POSITION_PCT=15
# ECHOFORGE_PHIC_MAX_TOTAL_EXPOSURE_PCT=30
# ECHOFORGE_PHIC_MAX_DRAWDOWN_PCT=8
# ECHOFORGE_PHIC_STOP_LOSS_PCT=1.5
# ECHOFORGE_PHIC_BANK_PROFIT_THRESHOLD_PCT=0.012
# ECHOFORGE_PHIC_BANK_TIER1_FRAC=0.60
# ECHOFORGE_PHIC_INFERENCE_FIDELITY=0.70
# ECHOFORGE_PHIC_GUARDIAN_MODE=shadow
# ECHOFORGE_PHIC_REGIME_CAPS={"LowVol":0.8,"HighVol":1.0,"Crisis":0.0}
# ECHOFORGE_PHIC_VPIN_CRISIS_THRESHOLD=0.70
# ECHOFORGE_PHIC_VPIN_HIGHVOL_THRESHOLD=0.40
# ECHOFORGE_PHIC_REGIME_DWELL_MIN=2
# ECHOFORGE_PHIC_STOP_LOSS_SELL_FRAC=0.65
# ECHOFORGE_PHIC_STOP_LOSS_BUY_FREEZE_MS=600000
# ECHOFORGE_PHIC_CAP_TRIM_BUY_FREEZE_MS=180000
# ECHOFORGE_PHIC_STOP_LOSS_REENTRY_BUFFER=0.010
#
# ── Echo aliveness tuning ──
# ECHOFORGE_PHIC_MIN_CONSENSUS_PCT=60      # aliveness gate (%) an echo must exceed to fire real orders
# ECHOFORGE_PHIC_SIGNAL_BOOST=0.03        # aliveness gained per passing signal (applied AFTER gate check)
# ECHOFORGE_PHIC_PAPER_SHADOW_ALPHA=0.10  # shadow aliveness EWMA learning rate (ghost-trade mode)
# ECHOFORGE_PHIC_PAPER_MIN_TRADES=4       # ghost trades required before resurrection to real-order mode
