# EchoForge environment variables — copy to .env and uncomment what you need.
# All variables are optional; defaults are shown in comments.

# ── Bridge ─────────────────────────────────────────────────────────────────

# ECHOFORGE_HOST=0.0.0.0
# ECHOFORGE_PORT=8765

# Comma-separated list of allowed CORS origins.
# Use '*' in development; set explicit origins in production.
# ECHOFORGE_CORS_ORIGINS=*

# ── NATS ───────────────────────────────────────────────────────────────────

# If unset, NATS publish is skipped silently (bridge still starts fine).
# NATS_URL=nats://localhost:4222

# ── Dashboard (Next.js — baked at build time) ──────────────────────────────

# URL the dashboard uses to reach the bridge.
# Change this if the bridge is running on a different host/port.
# NEXT_PUBLIC_BRIDGE_URL=http://localhost:8765

# ── Docker Compose port overrides ─────────────────────────────────────────

# BRIDGE_PORT=8765
# MOCK_VALR_PORT=8766
# TRACKER_PORT=8888
# NATS_PORT=4222
# DASHBOARD_PORT=3001

# ── Trystero tracker ────────────────────────────────────────────────────────

# Allow all WebTorrent rooms (default: true).
# Set to 'false' and populate TRACKER_ALLOW_HASHES to restrict rooms.
# TRACKER_ALLOW_ALL=true

# Comma-separated 8-char info-hash prefixes to allow when TRACKER_ALLOW_ALL=false.
# TRACKER_ALLOW_HASHES=a1b2c3d4,e5f6g7h8

# Set to any non-empty value to trust X-Forwarded-For (for reverse-proxy deployments).
# TRACKER_TRUST_PROXY=
