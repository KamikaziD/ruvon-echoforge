FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir fastapi uvicorn[standard] pydantic requests \
    numpy scikit-learn skl2onnx onnx

COPY tests/mock_valr/server.py ./server.py

EXPOSE 8766

CMD ["python", "-m", "uvicorn", "server:app", \
     "--host", "0.0.0.0", "--port", "8766", "--no-access-log"]
